name = "telegram-anti-spam-bot"
main = "src/index.ts"
compatibility_date = "2026-04-07"

rules = [
  { type = "Text", globs = ["**/*.html"], fallthrough = true }
]

[[d1_databases]]
binding = "DB"
database_name = "telegram_antispam"
database_id = "REPLACE_WITH_YOUR_D1_DATABASE_ID"

[[queues.producers]]
binding = "DELAY_QUEUE"
queue = "anti-spam-delay-queue"

[[queues.consumers]]
queue = "anti-spam-delay-queue"
max_batch_size = 10
max_batch_timeout = 0
max_retries = 0
